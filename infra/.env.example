# AWS credentials — used by Terraform and the AWS CLI
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Terraform variables (sensitive) — automatically picked up by Terraform via TF_VAR_* convention
TF_VAR_db_password=
TF_VAR_wompi_private_key=
TF_VAR_wompi_public_key=
TF_VAR_wompi_integrity_key=
TF_VAR_wompi_api_url=https://api-sandbox.co.uat.wompi.dev/v1

# Name of your existing AWS EC2 key pair (used for SSH, without .pem extension)
# deploy.sh expects the key file at ~/.ssh/<value>.pem
TF_VAR_ec2_key_name=
