{
  "compilerOptions": {
    "target": "ES2023",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "jest",
      "node",
      "vite/client",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src",
    "src/types",
    "jest.setup.ts",
    "jest.globals.ts"
  ]
}